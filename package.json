{
  "name": "pve-client",
  "version": "1.1.0",
  "description": "Proxmox Typescript API Client",
  "main": "./dist/index.cjs.js",
  "module": "./dist/index.es.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.es.js",
      "require": "./dist/index.cjs.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "example/auth": "tsx --env-file=.env examples/auth.ts",
    "example/terminal": "tsx --env-file=.env examples/terminal-local.ts",
    "example/tasks": "tsx --env-file=.env examples/tasks-live.ts",
    "docs:build": "typedoc src/index.ts --out generated/docs --theme default --excludePrivate --excludeProtected"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AlexanderSlaa/pve-client.git"
  },
  "keywords": [
    "Proxmox",
    "PVE",
    "pve",
    "Proxmox Virtual Environment",
    "API"
  ],
  "author": "Alexander Slaa",
  "license": "Apache-2.0",
  "type": "module",
  "bugs": {
    "url": "https://github.com/AlexanderSlaa/pve-client/issues"
  },
  "homepage": "https://alexanderslaa.github.io/pve-client/",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/npm": "^13.1.4",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@sourceregistry/semantic-release-jsr": "^1.1.1",
    "@types/node": "^25.3.0",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "eslint": "^10.2.1",
    "eslint-plugin-react": "^7.37.5",
    "globals": "^17.5.0",
    "tsx": "^4.20.4",
    "typedoc": "^0.28.17",
    "typescript": "^5.9.3",
    "vite": "^8.0.8",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.0.18"
  },
  "release": {
    "branches": [
      "main"
    ],
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      "@semantic-release/changelog",
      "@semantic-release/npm",
      "@sourceregistry/semantic-release-jsr",
      [
        "@semantic-release/git",
        {
          "assets": [
            "package.json",
            "jsr.json",
            "CHANGELOG.md"
          ],
          "message": "pve-client(release): 🚀 ${nextRelease.version} \n\n${nextRelease.notes}"
        }
      ]
    ]
  }
}
