{
  "$schema": "https://jsr.io/schema/config-file.v1.json",
  "name": "@sourceregistry/proxmox",
  "version": "1.3.0",
  "exports": {
    ".": "./jsr/index.js"
  },
  "publish": {
    "include": [
      "jsr/**/*.js",
      "jsr/**/*.d.ts",
      "dist/**/*.js",
      "dist/**/*.d.ts",
      "README.md",
      "LICENSE"
    ],
    "exclude": [
      "!jsr",
      "!jsr/**",
      "!dist",
      "!dist/**"
    ]
  }
}
